        <mxCell id="e2" style="endArrow=classic;html=1;rounded=1;strokeColor=#1E88E5;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="setup" target="rke2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;rounded=1;strokeColor=#1E88E5;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="rke2" target="appdeploy">
          <mxGeometry relative="1" as="geometry" />
