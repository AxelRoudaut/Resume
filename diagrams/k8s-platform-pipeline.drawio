        </mxCell>
        <mxCell id="rke2-ic2" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="rke2">
          <mxGeometry x="100" y="20" width="32" height="32" as="geometry" />
        </mxCell>
        <mxCell id="appdeploy" value="&lt;b style=&#39;font-size:15px;color:#e8eaed&#39;&gt;App Deployment&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#9aa0a8&#39; style=&#39;font-size:11px&#39;&gt;Ansible + Helm charts&lt;br&gt;templated with Jinja2&lt;br&gt;values from user config&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#20242e;strokeColor=#7EA7F0;strokeWidth=2.5;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1060" y="215" width="190" height="290" as="geometry" />
        </mxCell>
        <mxCell id="appdeploy-ic1" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="appdeploy">
          <mxGeometry x="58" y="20" width="32" height="32" as="geometry" />
        </mxCell>
        <mxCell id="appdeploy-ic2" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="appdeploy">
          <mxGeometry x="100" y="20" width="32" height="32" as="geometry" />
        </mxCell>

        <!-- ===================== RESULT ===================== -->
        <mxCell id="apps" value="&lt;b style=&#39;font-size:15px;color:#e8eaed&#39;&gt;Running Apps&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#9aa0a8&#39; style=&#39;font-size:11px&#39;&gt;workloads deployed&lt;br&gt;on the cluster&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#20242e;strokeColor=#4fd1c5;strokeWidth=2.5;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1370" y="215" width="190" height="290" as="geometry" />
        </mxCell>
        <mxCell id="apps-ic" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="apps">
          <mxGeometry x="78" y="20" width="34" height="34" as="geometry" />
        </mxCell>

        <!-- ===================== FLOW EDGES ===================== -->
        <mxCell id="c1" style="endArrow=classic;html=1;rounded=1;strokeColor=#1E88E5;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="config" target="tf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;rounded=1;strokeColor=#1E88E5;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="tf" target="setup">
          <mxGeometry relative="1" as="geometry" />
