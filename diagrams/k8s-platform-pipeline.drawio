<mxfile host="Resume" type="device">
  <diagram name="Kubernetes Platform Pipeline" id="k8s-platform-pipeline">
    <mxGraphModel dx="1620" dy="690" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1620" pageHeight="690" math="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== USER CONFIG (external input) ===================== -->
        <mxCell id="config" value="&lt;b style=&#39;font-size:14px;color:#e8eaed&#39;&gt;cluster-config.yaml&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#9aa0a8&#39; style=&#39;font-size:11px&#39;&gt;node count &#183; networks&lt;br&gt;app settings&lt;br&gt;&lt;br&gt;one small YAML file&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=7 5;fillColor=none;strokeColor=#9E9E9E;strokeWidth=2;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="215" width="180" height="290" as="geometry" />
        </mxCell>
        <mxCell id="config-ic" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="config">
          <mxGeometry x="74" y="20" width="32" height="32" as="geometry" />
        </mxCell>

        <!-- ===================== GITLAB CI PIPELINE ZONE ===================== -->
        <mxCell id="zone-ci" value="GITLAB CI &#183; SCHEDULED PIPELINE &#183; SINGLE CLICK" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FC6D26;fontColor=#FC6D26;strokeWidth=2.5;verticalAlign=top;align=left;fontSize=14;fontStyle=1;spacingLeft=50;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="270" y="110" width="1020" height="460" as="geometry" />
        </mxCell>
        <mxCell id="zone-ci-ic" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="zone-ci">
          <mxGeometry x="16" y="9" width="26" height="26" as="geometry" />
        </mxCell>

        <!-- ===================== EYEBROW LABELS ===================== -->
        <mxCell id="eb-1" value="1 &#183; PROVISION" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#9aa0a8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="170" width="190" height="18" as="geometry" />
        </mxCell>
        <mxCell id="eb-2" value="2 &#183; CONFIGURE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#9aa0a8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="170" width="190" height="18" as="geometry" />
        </mxCell>
        <mxCell id="eb-3" value="3 &#183; KUBERNETES" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#9aa0a8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="810" y="170" width="190" height="18" as="geometry" />
        </mxCell>
        <mxCell id="eb-4" value="4 &#183; APP DEPLOY" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#9aa0a8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1060" y="170" width="190" height="18" as="geometry" />
        </mxCell>

        <!-- ===================== PIPELINE STAGES ===================== -->
        <mxCell id="tf" value="&lt;b style=&#39;font-size:15px;color:#e8eaed&#39;&gt;Provision VMs&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#9aa0a8&#39; style=&#39;font-size:11px&#39;&gt;Terraform deploys VMs&lt;br&gt;on VMware ESXi&lt;br&gt;Windows &amp;amp; Linux&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#20242e;strokeColor=#9B6BE8;strokeWidth=2.5;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="310" y="215" width="190" height="290" as="geometry" />
        </mxCell>
        <mxCell id="tf-ic1" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="tf">
          <mxGeometry x="58" y="20" width="32" height="32" as="geometry" />
        </mxCell>
        <mxCell id="tf-ic2" style="sketch=0;pointerEvents=1;shadow=0;dashed=0;html=1;strokeColor=none;fillColor=#0091DA;align=center;outlineConnect=0;shape=mxgraph.veeam2.vmware_vsphere;" vertex="1" parent="tf">
          <mxGeometry x="100" y="20" width="32" height="32" as="geometry" />
        </mxCell>
        <mxCell id="setup" value="&lt;b style=&#39;font-size:15px;color:#e8eaed&#39;&gt;VM Setup&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#9aa0a8&#39; style=&#39;font-size:11px&#39;&gt;Ansible playbooks&lt;br&gt;IP &#183; hostname &#183; DNS&lt;br&gt;certificates &#183; SSH keys&lt;br&gt;connectivity checks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#20242e;strokeColor=#B7C0CC;strokeWidth=2.5;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="215" width="190" height="290" as="geometry" />
        </mxCell>
        <mxCell id="setup-ic" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="setup">
          <mxGeometry x="78" y="20" width="34" height="34" as="geometry" />
        </mxCell>
        <mxCell id="rke2" value="&lt;b style=&#39;font-size:15px;color:#e8eaed&#39;&gt;RKE2 Cluster&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#9aa0a8&#39; style=&#39;font-size:11px&#39;&gt;Ansible installs rke2&lt;br&gt;binaries on every node&lt;br&gt;cluster bootstraps&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#20242e;strokeColor=#326CE5;strokeWidth=2.5;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="810" y="215" width="190" height="290" as="geometry" />
        </mxCell>
        <mxCell id="rke2-ic1" style="shape=image;html=1;image=data:image/svg+xml,;" vertex="1" parent="rke2">
