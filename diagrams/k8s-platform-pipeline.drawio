        <mxCell id="e4" value="helm install" style="endArrow=classic;html=1;rounded=1;strokeColor=#4fd1c5;strokeWidth=2.5;fontColor=#4fd1c5;fontSize=11;labelBackgroundColor=#1b1f28;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="appdeploy" target="apps">
